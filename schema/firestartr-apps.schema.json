{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "state_repo": {
      "type": "string"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string"
          },
          "service_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["repo", "service_names"],
        "additionalProperties": false
      }
    }
  },
  "required": ["name", "state_repo", "services"],
  "additionalProperties": false
}
